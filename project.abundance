        {
          "atomType": "Code",
          "x": 0.7229845626072041,
          "y": 0.42378048780487804,
          "uniqueID": "id-8943",
          "ioValues": [
            {
              "name": "partAssembly",
              "ioValue": "__GEOMETRY_INPUT__"
            },
            {
              "name": "roundTo",
              "ioValue": 2
            },
            {
              "name": "sortBy",
              "ioValue": "quantity",
              "currentEquation": "quantity"
            }
          ],
          "interpreterVersion": 1,
          "code": "/**\n * Generates a cut list from all geometries in an assembly,\n * grouped by dimension and quantity. Handles deeply nested assemblies.\n */\nfunction run(\n  partAssembly: Assembly | Assembly[] | undefined = undefined,\n  roundTo: number = 2,\n  sortBy: string = \"quantity\",\n): string {\n  if (!partAssembly) {\n    return \"No assembly connected. Please connect a geometry input.\";\n  }\n\n  // Normalize input to array\n  const assemblies = Array.isArray(partAssembly)\n    ? partAssembly\n    : [partAssembly];\n\n  // Extract all individual parts with their bounds\n  const grouped: Record<string, number> = {};\n\n  // Recursively traverse nested assemblies to find all replicad geometry\n  function extractGeometries(obj: any): any[] {\n    if (!obj) return [];\n\n    // Skip strings\n    if (typeof obj === \"string\") {\n      return [];\n    }\n\n    // If this object has a boundingBox property, it's actual replicad geometry\n    if (obj.boundingBox && typeof obj.boundingBox === \"object\") {\n      return [obj];\n    }\n\n    // If this is an assembly (has geometry property), recurse into it\n    if (obj.geometry) {\n      const results: any[] = [];\n\n      // geometry can be an array of items or a single item\n      if (Array.isArray(obj.geometry)) {\n        for (const item of obj.geometry) {\n          results.push(...extractGeometries(item));\n        }\n      } else {\n        // Single geometry item\n        results.push(...extractGeometries(obj.geometry));\n      }\n      return results;\n    }\n\n    // If it's an array at top level, recurse into each element\n    if (Array.isArray(obj)) {\n      const results: any[] = [];\n      for (const item of obj) {\n        results.push(...extractGeometries(item));\n      }\n      return results;\n    }\n\n    return [];\n  }\n\n  // Process all assemblies\n  assemblies.forEach((assembly) => {\n    if (!assembly) return;\n\n    const geometries = extractGeometries(assembly.geometry);\n\n    geometries.forEach((geometry) => {\n      try {\n        const bbox = geometry.boundingBox;\n\n        // Validate boundingBox structure\n        if (\n          !bbox ||\n          typeof bbox !== \"object\" ||\n          !Array.isArray(bbox.bounds) ||\n          bbox.bounds.length !== 2\n        ) {\n          return;\n        }\n\n        // Extract dimensions from bounds\n        const minPoint = bbox.bounds[0];\n        const maxPoint = bbox.bounds[1];\n\n        if (\n          !Array.isArray(minPoint) ||\n          !Array.isArray(maxPoint) ||\n          minPoint.length < 3 ||\n          maxPoint.length < 3\n        ) {\n          return;\n        }\n\n        const x = Math.abs(maxPoint[0] - minPoint[0]);\n        const y = Math.abs(maxPoint[1] - minPoint[1]);\n        const z = Math.abs(maxPoint[2] - minPoint[2]);\n\n        // Sort dimensions for consistency\n        const dims = [x, y, z]\n          .sort((a, b) => b - a)\n          .map((d) => d.toFixed(roundTo))\n          .join(\" × \");\n\n        grouped[dims] = (grouped[dims] || 0) + 1;\n      } catch (e) {\n        console.warn(\"Could not extract bounds for geometry:\", e);\n      }\n    });\n  });\n\n  if (Object.keys(grouped).length === 0) {\n    return \"No valid geometries found in assembly.\";\n  }\n\n  // Sort results\n  const sorted = Object.entries(grouped).sort((a, b) => {\n    if (sortBy === \"quantity\") {\n      return b[1] - a[1]; // Most common first\n    } else {\n      return a[0].localeCompare(b[0]); // Alphabetical\n    }\n  });\n\n  // Generate markdown table\n  let table =\n    \"| Dimensions (X × Y × Z) | Quantity |\\n|------------------------|----------|\\n\";\n  let totalParts = 0;\n\n  sorted.forEach(([dims, qty]) => {\n    table += `| ${dims} mm | ${qty} |\\n`;\n    totalParts += qty;\n  });\n\n  table += `\\n**Total Parts:** ${totalParts}`;\n  console.log(table)\n  return table;\n}",
          "compiledCode": "\"use strict\";\n/**\n * Generates a cut list from all geometries in an assembly,\n * grouped by dimension and quantity. Handles deeply nested assemblies.\n */\nfunction run(partAssembly = undefined, roundTo = 2, sortBy = \"quantity\") {\n    if (!partAssembly) {\n        return \"No assembly connected. Please connect a geometry input.\";\n    }\n    // Normalize input to array\n    const assemblies = Array.isArray(partAssembly)\n        ? partAssembly\n        : [partAssembly];\n    // Extract all individual parts with their bounds\n    const grouped = {};\n    // Recursively traverse nested assemblies to find all replicad geometry\n    function extractGeometries(obj) {\n        if (!obj)\n            return [];\n        // Skip strings\n        if (typeof obj === \"string\") {\n            return [];\n        }\n        // If this object has a boundingBox property, it's actual replicad geometry\n        if (obj.boundingBox && typeof obj.boundingBox === \"object\") {\n            return [obj];\n        }\n        // If this is an assembly (has geometry property), recurse into it\n        if (obj.geometry) {\n            const results = [];\n            // geometry can be an array of items or a single item\n            if (Array.isArray(obj.geometry)) {\n                for (const item of obj.geometry) {\n                    results.push(...extractGeometries(item));\n                }\n            }\n            else {\n                // Single geometry item\n                results.push(...extractGeometries(obj.geometry));\n            }\n            return results;\n        }\n        // If it's an array at top level, recurse into each element\n        if (Array.isArray(obj)) {\n            const results = [];\n            for (const item of obj) {\n                results.push(...extractGeometries(item));\n            }\n            return results;\n        }\n        return [];\n    }\n    // Process all assemblies\n    assemblies.forEach((assembly) => {\n        if (!assembly)\n            return;\n        const geometries = extractGeometries(assembly.geometry);\n        geometries.forEach((geometry) => {\n            try {\n                const bbox = geometry.boundingBox;\n                // Validate boundingBox structure\n                if (!bbox ||\n                    typeof bbox !== \"object\" ||\n                    !Array.isArray(bbox.bounds) ||\n                    bbox.bounds.length !== 2) {\n                    return;\n                }\n                // Extract dimensions from bounds\n                const minPoint = bbox.bounds[0];\n                const maxPoint = bbox.bounds[1];\n                if (!Array.isArray(minPoint) ||\n                    !Array.isArray(maxPoint) ||\n                    minPoint.length < 3 ||\n                    maxPoint.length < 3) {\n                    return;\n                }\n                const x = Math.abs(maxPoint[0] - minPoint[0]);\n                const y = Math.abs(maxPoint[1] - minPoint[1]);\n                const z = Math.abs(maxPoint[2] - minPoint[2]);\n                // Sort dimensions for consistency\n                const dims = [x, y, z]\n                    .sort((a, b) => b - a)\n                    .map((d) => d.toFixed(roundTo))\n                    .join(\" × \");\n                grouped[dims] = (grouped[dims] || 0) + 1;\n            }\n            catch (e) {\n                console.warn(\"Could not extract bounds for geometry:\", e);\n            }\n        });\n    });\n    if (Object.keys(grouped).length === 0) {\n        return \"No valid geometries found in assembly.\";\n    }\n    // Sort results\n    const sorted = Object.entries(grouped).sort((a, b) => {\n        if (sortBy === \"quantity\") {\n            return b[1] - a[1]; // Most common first\n        }\n        else {\n            return a[0].localeCompare(b[0]); // Alphabetical\n        }\n    });\n    // Generate markdown table\n    let table = \"| Dimensions (X × Y × Z) | Quantity |\\n|------------------------|----------|\\n\";\n    let totalParts = 0;\n    sorted.forEach(([dims, qty]) => {\n        table += `| ${dims} mm | ${qty} |\\n`;\n        totalParts += qty;\n    });\n    table += `\\n**Total Parts:** ${totalParts}`;\n    console.log(table);\n    return table;\n}\n"
        },
