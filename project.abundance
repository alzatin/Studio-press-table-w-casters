                {
                  "atomType": "Code",
                  "x": 0.32584269662921345,
                  "y": 0.3940298507462686,
                  "uniqueID": "id-24138",
                  "ioValues": [
                    {
                      "name": "base1",
                      "ioValue": 4
                    },
                    {
                      "name": "base2",
                      "ioValue": 2
                    },
                    {
                      "name": "tr_height",
                      "ioValue": 1
                    },
                    {
                      "name": "height",
                      "ioValue": 4
